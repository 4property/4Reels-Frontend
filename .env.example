# Copy to .env.local and adjust.

# API layer -----------------------------------------------------------------
# Keep the existing product screens on mock data while the backend MVP only
# exposes the GoHighLevel test endpoints.
VITE_USE_MOCK=true
VITE_API_URL=/api

# GoHighLevel MVP requests always bypass the mock API and go here.
VITE_MVP_API_URL=https://test.sydney2000.club
# API errors include trace details in the browser console unless this is false.
VITE_API_TRACE=true

# GoHighLevel Marketplace MVP -----------------------------------------------
# In the real GHL custom page, the frontend requests encrypted user context
# from the parent iframe and asks the backend to decrypt it. URL/env values are
# only local-development fallbacks.
VITE_GHL_MVP_ENABLED=true
VITE_GHL_CONTEXT_TIMEOUT_MS=2500
# Used only when the frontend can detect location_id but GHL does not return user_id.
VITE_GHL_FALLBACK_USER_ID=manual-test

# Direct admin MVP mode. When enabled, visiting /admin or adding ?admin=1
# creates a local super-admin session without needing the GHL iframe context.
VITE_MVP_ADMIN_ENABLED=true
VITE_MVP_ADMIN_USER_ID=admin-local
VITE_MVP_ADMIN_NAME=Platform Admin
VITE_MVP_ADMIN_EMAIL=admin@example.com
# VITE_GHL_LOCATION_ID=
# VITE_GHL_USER_ID=
# VITE_GHL_USER_NAME=
# VITE_GHL_USER_EMAIL=

# Error tracking ------------------------------------------------------------
# If set, unhandled errors are POSTed to this endpoint (JSON payload with
# message, stack, context, url, userAgent, timestamp).
# Leave empty to log to console only. In dev we always log to console.
# VITE_ERROR_ENDPOINT=https://your-ingest.example.com/errors
